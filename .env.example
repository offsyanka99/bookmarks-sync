# Bookmark sync API port
SERVER_PORT=31059
# Admin web UI port (separate from the API)
ADMIN_PORT=31060
SERVER_HOST=0.0.0.0
DB_PATH=./data/bookmarks.db
ALLOW_NEW_SYNCS=true
MAX_SYNC_SIZE_BYTES=1048576
STATUS_MESSAGE=Bookmarks Sync service is online

# Admin bootstrap (create on first run only). To re-apply later:
# set RESET_ADMIN_PASSWORD=true, restart once, then remove that line.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin-password
# RESET_ADMIN_PASSWORD=true

# Required for signed session cookies
SESSION_SECRET=generate-a-long-random-string

# Set true when serving over HTTPS
COOKIE_SECURE=false
