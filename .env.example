# Bookmark sync API port
SERVER_PORT=31059
# Admin web UI port (separate from the API)
ADMIN_PORT=31060
SERVER_HOST=0.0.0.0
# Optional: LAN IP/hostname + host-mapped ports for startup log URLs only
# (does not change bind address — keep SERVER_HOST=0.0.0.0 in Docker)
# PUBLIC_HOST=10.10.20.40
# PUBLIC_API_PORT=31039
# PUBLIC_ADMIN_PORT=31040
DB_PATH=./data/bookmarks.db
ALLOW_NEW_SYNCS=true
MAX_SYNC_SIZE_BYTES=1048576
STATUS_MESSAGE=Bookmarks Sync service is online

# --- Admin credentials ---
# Default: leave ADMIN_PASSWORD unset. On first start, open the admin UI and
# complete /setup (username is always "admin" unless you set ADMIN_USERNAME).
# Optional headless bootstrap (creates admin at process start if none exists):
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=your-strong-password
# Emergency password reset (once): set both, restart, then remove RESET line.
# RESET_ADMIN_PASSWORD=true

# Session cookie signing secret.
# Optional: if unset/empty, a random secret is written next to the DB as
# data/.session-secret and reused on restarts.
# Or set explicitly:
#   openssl rand -hex 32
# SESSION_SECRET=

# Admin portal session idle timeout (minutes). Default 15 if unset.
# Cookie is rolling (refreshed on each request while you use the UI).
SESSION_MAX_AGE_MINUTES=15

# UI clock format for admin portal + browser extensions (from GET /info).
# 24h (default) | 12h  — also accepts 24, 12, h23, h12, ampm
TIME_FORMAT=24h

# Set true when serving admin UI over HTTPS
COOKIE_SECURE=false

# CORS for the bookmark API (browser clients only).
# Empty = no CORS headers (recommended for curl / native extension clients).
# "*" = allow any origin (dev only).
# Or comma-separated allowlist: https://app.example.com,chrome-extension://abcdef
CORS_ORIGINS=

# When behind Caddy/nginx/Traefik, set so req.ip (rate limits / login logs) is correct.
# true | 1 | hop count | Express trust proxy value
TRUST_PROXY=false

# Rate limits (optional)
# LOGIN_RATE_MAX=20
# LOGIN_RATE_WINDOW_MS=900000
# API_KEY_RATE_MAX=60
# API_KEY_RATE_WINDOW_MS=900000

# Logging (stdout for Docker/Dozzle; rotating files under LOG_DIR)
LOG_LEVEL=info
LOG_DIR=./data/logs
LOG_TO_STDOUT=true
LOG_TO_FILE=true
# json (default in production) | pretty (default in development)
# LOG_STDOUT_FORMAT=json
LOG_MAX_FILES=14d
LOG_MAX_SIZE=20m
