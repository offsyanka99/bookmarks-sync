# Bookmark sync API port
SERVER_PORT=31059
# Admin web UI port (separate from the API)
ADMIN_PORT=31060
SERVER_HOST=0.0.0.0
DB_PATH=./data/bookmarks.db
ALLOW_NEW_SYNCS=true
MAX_SYNC_SIZE_BYTES=1048576
STATUS_MESSAGE=Bookmarks Sync service is online

# Admin bootstrap (create on first run only). To re-apply later:
# set RESET_ADMIN_PASSWORD=true, restart once, then remove that line.
# In production (NODE_ENV=production), ADMIN_PASSWORD must be strong (not "admin", min 8 chars).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
# RESET_ADMIN_PASSWORD=true

# Required for signed session cookies.
# In production: must be set, ≥16 chars, and not a known placeholder.
# Generate a strong secret (either works; 64 hex chars):
#   openssl rand -hex 32
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=generate-a-long-random-string

# Set true when serving admin UI over HTTPS
COOKIE_SECURE=false

# CORS for the bookmark API (browser clients only).
# Empty = no CORS headers (recommended for curl / native extension clients).
# "*" = allow any origin (dev only).
# Or comma-separated allowlist: https://app.example.com,chrome-extension://abcdef
CORS_ORIGINS=

# When behind Caddy/nginx/Traefik, set so req.ip (rate limits / login logs) is correct.
# true | 1 | hop count | Express trust proxy value
TRUST_PROXY=false

# Rate limits (optional)
# LOGIN_RATE_MAX=20
# LOGIN_RATE_WINDOW_MS=900000
# API_KEY_RATE_MAX=60
# API_KEY_RATE_WINDOW_MS=900000

# Logging (stdout for Docker/Dozzle; rotating files under LOG_DIR)
LOG_LEVEL=info
LOG_DIR=./data/logs
LOG_TO_STDOUT=true
LOG_TO_FILE=true
# json (default in production) | pretty (default in development)
# LOG_STDOUT_FORMAT=json
LOG_MAX_FILES=14d
LOG_MAX_SIZE=20m
