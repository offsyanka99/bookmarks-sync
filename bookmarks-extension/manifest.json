{
  "manifest_version": 3,
  "name": "Bookmarks Sync",
  "version": "0.2.0",
  "description": "Sync browser bookmarks with your self-hosted bookmarks-sync server.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Bookmarks Sync",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["bookmarks", "storage", "alarms", "notifications"],
  "optional_host_permissions": ["http://*/*", "https://*/*"],
  "minimum_chrome_version": "116"
}
