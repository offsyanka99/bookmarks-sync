{
  "name": "bookmarks-sync",
  "version": "1.2.0",
  "description": "Self-hosted multi-user bookmark sync server (SQLite + Node.js)",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "ext:sync": "node bookmarks-extension/scripts/sync-firefox.mjs",
    "ext:firefox": "node bookmarks-extension/scripts/sync-firefox.mjs",
    "ext:check": "node bookmarks-extension/scripts/check-extension-sync.mjs",
    "ext:pack": "node bookmarks-extension/scripts/pack.mjs all",
    "ext:pack-chrome": "node bookmarks-extension/scripts/pack.mjs chrome",
    "ext:pack-firefox": "node bookmarks-extension/scripts/pack.mjs firefox"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "bookmarks",
    "sync",
    "sqlite",
    "self-hosted"
  ],
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-session": "^1.19.0",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0",
    "uuid": "^11.0.5",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  }
}
